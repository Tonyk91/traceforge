# ── LLM / embeddings ─────────────────────────────────────────────
# TraceForge is Azure-first. Set these to use Azure OpenAI. If unset,
# the pipeline falls back to a deterministic local engine so the full
# flow (and CI eval) runs offline with zero external calls.
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-large

# ── Gold index (retrieval) ───────────────────────────────────────
# Set to use Azure AI Search for the gold layer. If unset, TraceForge
# uses a local in-process hybrid index (numpy vectors + BM25).
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX=traceforge-requirements

# ── Bronze storage ───────────────────────────────────────────────
# Azure Blob (or any S3-compatible store). If unset, uses local ./data/bronze.
AZURE_STORAGE_CONNECTION_STRING=
BRONZE_CONTAINER=bronze

# ── Access control ───────────────────────────────────────────────
# Clearance ordering used to enforce need-to-know at retrieval time.
CLEARANCE_LEVELS=OPEN,RESTRICTED,SECRET
